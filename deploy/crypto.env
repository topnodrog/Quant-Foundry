# Crypto-pack additions for Open Foundry's deploy/.env
# ----------------------------------------------------
# Append these to  C:\dev\open-foundry\deploy\.env  (created from .env.example).
# They tell the api-gateway to load ONLY core + our external crypto pack, and
# to mount the pack (which lives in this repo) into the container.

# Load only core + crypto — omit the bundled nhs-acute / aml / supply-chain
# packs so their FHIR/CDM facades and schemas stay out of a crypto deployment.
DOMAIN_PACKS=core,crypto

# Container-side path the api-gateway scans for external packs.
DOMAIN_PACKS_EXTRA_DIRS=/external-packs

# Host path mounted read-only at /external-packs. Points straight at the pack
# directory (it contains pack.yaml, so the loader treats it as a direct pack).
# Docker Desktop on Windows accepts forward-slashed absolute paths.
DOMAIN_PACKS_HOST_DIR=C:/dev/api.quiverquant.com/ontology/crypto-pack

# Copy to .env and fill in what you have. Every source runs on its free tier
# by default; setting a *_PAID_* var upgrades that source's tier automatically
# (see src/quiverquant/config.py). Sources with no key needed here at all:
# DefiLlama (TVL), CCXT, Blockchair, SEC EDGAR, GitHub (works keyless too).

# #3 on-chain — free signup: https://etherscan.io/apis
ETHERSCAN_API_KEY=
BLOCKCHAIR_API_KEY=

# #4 sentiment — free signup: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# #5 dev activity — raises GitHub's 60/hr keyless limit to 5000/hr
GITHUB_TOKEN=

# #7 whale alerts — not yet wired up (see collectors/whale_alert.py)
WHALE_ALERT_SOURCE=

# #8 smart money
NANSEN_API_KEY=
NANSEN_PAID_API_KEY=
DUNE_API_KEY=
DUNE_PAID_API_KEY=

# DefiLlama pro plan (unlocks/emissions data only — TVL is free without this)
DEFILLAMA_API_KEY=

# §3 scrape gap-filler — VC portfolio pages via Firecrawl. Optional: /scrape works
# keyless (per-IP rate-limited); a key (fc-...) lifts the limits. Free signup:
# https://firecrawl.dev  (JSON extraction ~5 credits/page — see research/firecrawl.md)
FIRECRAWL_API_KEY=
